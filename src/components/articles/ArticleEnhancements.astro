<script>
    import mermaid from "mermaid";
    import svgPanZoom from "svg-pan-zoom";

    const articleBody = document.querySelector(".article-body");
    const tocLinks = Array.from(document.querySelectorAll("[data-toc-link]"));
    const internalLinks = Array.from(
        document.querySelectorAll(
            '.article-body a[href^="#"], [data-toc-link][href^="#"]',
        ),
    );
    const pendingDiagrams = Array.from(
        document.querySelectorAll<HTMLElement>(".article-body pre.mermaid"),
    );
    const copyButtons = Array.from(
        document.querySelectorAll(".article-body [data-copy-code]"),
    );
    const headings = tocLinks
        .map((link) => {
            const id = link.getAttribute("data-heading-id");
            if (!id) return null;

            const heading = document.getElementById(id);
            if (!heading) return null;

            return { id, link, heading };
        })
        .filter(Boolean);

    const scrollToHash = (hash, updateUrl = true) => {
        if (!hash || hash === "#") return;

        const target = document.getElementById(hash.slice(1));
        if (!target) return;

        const lenis = window.__lenis;

        if (updateUrl) {
            window.history.pushState(null, "", hash);
        }

        if (lenis) {
            lenis.scrollTo(target, { offset: -24 });
            return;
        }

        target.scrollIntoView({ behavior: "smooth", block: "start" });
    };

    for (const link of internalLinks) {
        link.addEventListener("click", (event) => {
            const href = link.getAttribute("href");
            if (!href?.startsWith("#")) return;

            event.preventDefault();
            scrollToHash(href);
        });
    }

    for (const button of copyButtons) {
        button.addEventListener("click", async () => {
            const block = button.closest(".code-block");
            const code = block?.querySelector("pre code");
            if (!block || !code) return;

            try {
                await navigator.clipboard.writeText(code.textContent ?? "");
                button.classList.add("is-copied");

                window.setTimeout(() => {
                    button.classList.remove("is-copied");
                }, 1600);
            } catch {
                button.classList.add("copy-failed");

                window.setTimeout(() => {
                    button.classList.remove("copy-failed");
                }, 1600);
            }
        });
    }

    if (headings.length > 0) {
        const setActive = (activeId) => {
            for (const item of headings) {
                item.link.classList.toggle("is-active", item.id === activeId);
            }
        };

        const updateActiveHeading = () => {
            let currentId = headings[0].id;
            const offset = window.innerHeight * 0.2;

            for (const item of headings) {
                if (item.heading.getBoundingClientRect().top - offset <= 0) {
                    currentId = item.id;
                } else {
                    break;
                }
            }

            setActive(currentId);
        };

        updateActiveHeading();
        window.addEventListener("scroll", updateActiveHeading, {
            passive: true,
        });
        window.addEventListener("resize", updateActiveHeading);
    }

    if (articleBody && window.location.hash) {
        window.requestAnimationFrame(() => {
            scrollToHash(window.location.hash, false);
        });
    }

    // ── Mermaid client-side renderer ────────────────────────────────────────
    if (pendingDiagrams.length > 0) {
        type DiagramItem = {
            source: string;
            frame: HTMLDivElement | null;
        };

        const diagrams: DiagramItem[] = pendingDiagrams.map((el) => ({
            source: el.textContent ?? "",
            frame: null,
        }));

        let panZoomInstances: ReturnType<typeof svgPanZoom>[] = [];
        let renderGeneration = 0;

        const getMermaidConfig = (isDark: boolean) => ({
            startOnLoad: false,
            theme: "base" as const,
            themeVariables: isDark
                ? {
                      background: "#1a1814",
                      mainBkg: "#2c2820",
                      primaryColor: "#2c2820",
                      primaryTextColor: "#f0ede6",
                      primaryBorderColor: "rgba(240, 237, 230, 0.2)",
                      lineColor: "rgba(240, 237, 230, 0.4)",
                      secondaryColor: "#252118",
                      tertiaryColor: "#302b22",
                      edgeLabelBackground: "#1a1814",
                      nodeBorder: "#504840",
                      clusterBkg: "#252118",
                      clusterBorder: "rgba(240, 237, 230, 0.15)",
                      titleColor: "#f0ede6",
                      attributeBackgroundColorEven: "#252118",
                      attributeBackgroundColorOdd: "#2c2820",
                  }
                : {
                      background: "#fffaf2",
                      mainBkg: "#f6efe5",
                      primaryColor: "#f6efe5",
                      primaryTextColor: "#24221d",
                      primaryBorderColor: "rgba(36, 34, 29, 0.18)",
                      lineColor: "rgba(36, 34, 29, 0.4)",
                      secondaryColor: "#eee6d9",
                      tertiaryColor: "#e8dfd1",
                      edgeLabelBackground: "#fffaf2",
                      nodeBorder: "#c8bfb0",
                      clusterBkg: "#f6efe5",
                      clusterBorder: "rgba(36, 34, 29, 0.15)",
                      titleColor: "#24221d",
                      attributeBackgroundColorEven: "#f6efe5",
                      attributeBackgroundColorOdd: "#fffaf2",
                  },
            fontFamily: '"Times New Roman", Georgia, serif',
            fontSize: "14px",
            securityLevel: "strict" as const,
        });

        const renderDiagrams = async (isDark: boolean) => {
            renderGeneration++;
            const gen = renderGeneration;

            for (const inst of panZoomInstances) {
                try {
                    inst.destroy();
                } catch {}
            }
            panZoomInstances = [];

            mermaid.initialize(getMermaidConfig(isDark));

            for (let i = 0; i < diagrams.length; i++) {
                if (gen !== renderGeneration) return;

                const item = diagrams[i];
                if (!item.source.trim()) continue;

                try {
                    const { svg } = await mermaid.render(
                        `mermaid-${gen}-${i}`,
                        item.source,
                    );

                    if (gen !== renderGeneration) return;

                    if (!item.frame) {
                        const frame = document.createElement("div");
                        frame.className = "mermaid-frame";
                        frame.setAttribute("data-lenis-prevent-wheel", "");
                        frame.addEventListener(
                            "wheel",
                            (e) => e.stopPropagation(),
                            { passive: false },
                        );
                        pendingDiagrams[i].replaceWith(frame);
                        item.frame = frame;
                    }

                    item.frame.innerHTML = svg;

                    const svgEl = item.frame.querySelector("svg");
                    if (!svgEl) continue;

                    const pzInstance = svgPanZoom(svgEl, {
                        center: true,
                        controlIconsEnabled: false,
                        dblClickZoomEnabled: true,
                        fit: true,
                        maxZoom: 12,
                        minZoom: 0.5,
                        mouseWheelZoomEnabled: true,
                        panEnabled: true,
                        pinchZoomEnabled: true,
                        preventMouseEventsDefault: true,
                        zoomEnabled: true,
                        zoomScaleSensitivity: 0.3,
                    });
                    panZoomInstances.push(pzInstance);
                } catch (err) {
                    console.error(`Mermaid render error (diagram ${i}):`, err);
                }
            }
        };

        const isDark = document.documentElement.classList.contains("dark");
        await renderDiagrams(isDark);

        const themeObserver = new MutationObserver((mutations) => {
            for (const mutation of mutations) {
                if (
                    mutation.type === "attributes" &&
                    mutation.attributeName === "class"
                ) {
                    const newIsDark =
                        document.documentElement.classList.contains("dark");
                    renderDiagrams(newIsDark);
                    break;
                }
            }
        });

        themeObserver.observe(document.documentElement, {
            attributes: true,
            attributeFilter: ["class"],
        });
    }
</script>

