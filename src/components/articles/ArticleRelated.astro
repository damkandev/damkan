---
import type { Article } from "../../services/articles";
import { getLocalizedArticlePath } from "../../i18n/routes";
import type { Locale } from "../../i18n/config";

interface Props {
    relatedArticles: Article[];
    locale: Locale;
    description: string;
    emptyExcerpt: string;
    title: string;
}

const { description, emptyExcerpt, locale, relatedArticles, title } = Astro.props;

if (relatedArticles.length === 0) {
    return null;
}
---

<aside class="space-y-4 border-t border-black/10 pt-5 sm:pt-6 dark:border-white/10">
    <div class="space-y-1">
        <h2 class="text-xl font-semibold sm:text-2xl">{title}</h2>
        <p class="text-sm text-black/60 dark:text-white/60">
            {description}
        </p>
    </div>

    <div class="grid gap-3">
        {
            relatedArticles.map((relatedArticle) => (
                <a
                    class="block border border-black/10 p-4 transition-colors hover:border-black/30 dark:border-white/10 dark:hover:border-white/30"
                    href={getLocalizedArticlePath(locale, relatedArticle.slug)}
                >
                    <div class="space-y-2">
                        <h3 class="text-lg font-semibold">
                            {relatedArticle.title}
                        </h3>
                        <p class="text-sm text-black/70 dark:text-white/70">
                            {relatedArticle.excerpt || emptyExcerpt}
                        </p>
                    </div>
                </a>
            ))
        }
    </div>
</aside>
