<button
  id="theme-toggle"
  aria-label="Cambiar tema"
  class="fixed top-4 right-4 z-50 flex h-9 w-9 items-center justify-center border border-black/10 bg-[#FFFCFC]/80 text-[#24221D] backdrop-blur-sm transition-colors hover:border-black/30 dark:border-white/10 dark:bg-[#1c1a16]/80 dark:text-[#f0ede6] dark:hover:border-white/30"
>
  <!-- Moon — visible in light mode -->
  <svg id="theme-icon-moon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
  </svg>
  <!-- Sun — visible in dark mode -->
  <svg id="theme-icon-sun" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="hidden">
    <circle cx="12" cy="12" r="5"/>
    <line x1="12" y1="1" x2="12" y2="3"/>
    <line x1="12" y1="21" x2="12" y2="23"/>
    <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
    <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
    <line x1="1" y1="12" x2="3" y2="12"/>
    <line x1="21" y1="12" x2="23" y2="12"/>
    <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
    <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
  </svg>
</button>

<script>
  const toggle = document.getElementById("theme-toggle");
  const moonIcon = document.getElementById("theme-icon-moon");
  const sunIcon = document.getElementById("theme-icon-sun");
  const html = document.documentElement;

  const syncIcons = () => {
    const isDark = html.classList.contains("dark");
    moonIcon?.classList.toggle("hidden", isDark);
    sunIcon?.classList.toggle("hidden", !isDark);
  };

  syncIcons();

  toggle?.addEventListener("click", () => {
    const isDark = html.classList.toggle("dark");
    localStorage.setItem("theme", isDark ? "dark" : "light");
    syncIcons();
  });
</script>
