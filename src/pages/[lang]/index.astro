---
import "../../styles/global.css";
import Favicons from "../../components/Favicons.astro";
import LanguageSwitcher from "../../components/LanguageSwitcher.astro";
import Lenis from "../../components/Lenis.astro";
import ThemeToggle from "../../components/ThemeToggle.astro";
import VercelAnalytics from "../../components/VercelAnalytics.astro";
import { SUPPORTED_LOCALES, isLocale, type Locale } from "../../i18n/config";
import { getLocalizedArticlesPath, getLocalizedHomePath } from "../../i18n/routes";
import { getMessages } from "../../i18n/ui";
import { listArticles } from "../../services/articles";

export async function getStaticPaths() {
  return SUPPORTED_LOCALES.map((lang) => ({
    params: { lang },
  }));
}

const localeParam = Astro.params.lang;

if (!isLocale(localeParam)) {
  return Astro.redirect(getLocalizedHomePath("es"), 302);
}

const locale: Locale = localeParam;
const copy = getMessages(locale);
const articles = await listArticles(locale);
const latestArticles = articles.slice(0, 3);
const languageOptions = SUPPORTED_LOCALES.map((candidateLocale) => ({
  href: getLocalizedHomePath(candidateLocale),
  label: candidateLocale.toUpperCase(),
  locale: candidateLocale,
}));
---

<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <link
      rel="preload"
      href="/fonts/lora-latin.woff2"
      as="font"
      type="font/woff2"
      crossorigin="anonymous"
    />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{copy.home.seoTitle}</title>
    <meta name="description" content={copy.home.seoDescription} />
    <Favicons />
    <link rel="canonical" href={Astro.url.href} />
    <link rel="alternate" hreflang="es" href={new URL(getLocalizedHomePath("es"), Astro.url).href} />
    <link rel="alternate" hreflang="en" href={new URL(getLocalizedHomePath("en"), Astro.url).href} />
    <script is:inline>
      (function () {
        var s = localStorage.getItem("theme");
        var p = window.matchMedia("(prefers-color-scheme: dark)").matches;
        if (s === "dark" || (!s && p)) {
          document.documentElement.classList.add("dark");
        }
      })();
    </script>
  </head>
  <body
    class="min-h-screen flex items-center justify-center bg-[#FFFCFC] text-[#24221D] p-8 transition-colors dark:bg-[#1c1a16] dark:text-[#f0ede6]"
  >
    <Lenis />
    <LanguageSwitcher
      currentLocale={locale}
      label={copy.languageSwitcher.label}
      options={languageOptions}
    />
    <ThemeToggle ariaLabel={copy.themeToggle.label} />
    <main class="w-full max-w-3xl mx-auto flex flex-col gap-4 text-left">
      <h1 class="text-4xl font-semibold">Damián Panes</h1>
      <p class="text-lg leading-relaxed">
        {copy.home.bio}
      </p>

      <section class="space-y-4">
        <h2 class="text-2xl font-semibold">{copy.home.articlesTitle}</h2>
        {
          latestArticles.length === 0 ? (
            <p class="text-sm text-black/40 dark:text-white/40">{copy.home.empty}</p>
          ) : (
            <ul class="grid gap-3">
              {latestArticles.map((article) => (
                <li>
                  <a
                    class="block border-2 border-black/10 p-4 transition hover:border-black/30 dark:border-white/10 dark:hover:border-white/30"
                    href={`/${locale}/articles/${article.slug}/`}
                  >
                    <p class="text-xl font-medium">{article.title}</p>
                    <p class="text-slate-600 dark:text-slate-400">
                      {article.excerpt || copy.home.fallbackExcerpt}
                    </p>
                  </a>
                </li>
              ))}
            </ul>
          )
        }
        <a
          class="font-semibold hover:text-black/30 dark:hover:text-white/30"
          href={getLocalizedArticlesPath(locale)}
        >
          {copy.home.seeMore}
        </a>
      </section>

      <section class="space-y-4">
        <h3 class="text-xl font-semibold">{copy.home.socialTitle}</h3>
        <ul class="list-disc list-inside text-base text-current space-y-2">
          <li>
            <a
              class="hover:underline"
              href="https://www.linkedin.com/in/damianpanes/"
              rel="noopener noreferrer"
              target="_blank">LinkedIn</a
            >
          </li>
          <li>
            <a
              class="hover:underline"
              href="https://github.com/damkandev"
              rel="noopener noreferrer"
              target="_blank">GitHub</a
            >
          </li>
          <li>
            <a
              class="hover:underline"
              href="https://www.instagram.com/damian.panes/"
              rel="noopener noreferrer"
              target="_blank">Instagram</a
            >
          </li>
          <li>
            <a
              class="hover:underline"
              href="https://www.goodreads.com/user/show/196006762-dami-n-panes"
              rel="noopener noreferrer"
              target="_blank">GoodReads</a
            >
          </li>
          <li>
            <a
              class="hover:underline"
              href="https://www.youtube.com/@damianpanes"
              rel="noopener noreferrer"
              target="_blank">Youtube</a
            >
          </li>
        </ul>
      </section>
    </main>
    <VercelAnalytics />
  </body>
</html>
