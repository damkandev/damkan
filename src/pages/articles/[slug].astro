---
import PreferredLocaleRedirect from "../../components/PreferredLocaleRedirect.astro";
import { getLocalizedArticlesPath } from "../../i18n/routes";
import { listLegacyArticleSlugRoutes } from "../../services/articles";

export async function getStaticPaths() {
  const routes = await listLegacyArticleSlugRoutes();

  return routes.map((route) => ({
    params: { slug: route.slug },
    props: {
      routesByLocale: route.routesByLocale,
    },
  }));
}

const { routesByLocale } = Astro.props;
---

<PreferredLocaleRedirect
  fallbackPath={routesByLocale.es || routesByLocale.en || getLocalizedArticlesPath("es")}
  routesByLocale={routesByLocale}
/>
