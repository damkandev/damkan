---
import "../../styles/global.css";
import Lenis from "../../components/Lenis.astro";
import ThemeToggle from "../../components/ThemeToggle.astro";
import { listArticles } from "../../services/articles";

const articles = await listArticles();
---

<html lang="es">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width" />
        <title>Artículos | Damián Panes</title>
        <script is:inline>
            (function () {
                var s = localStorage.getItem("theme");
                var p = window.matchMedia(
                    "(prefers-color-scheme: dark)",
                ).matches;
                if (s === "dark" || (!s && p)) {
                    document.documentElement.classList.add("dark");
                }
            })();
        </script>
    </head>
    <body
        class="min-h-screen flex items-center justify-center bg-[#FFFCFC] text-[#24221D] p-8 transition-colors dark:bg-[#1c1a16] dark:text-[#f0ede6]"
    >
        <Lenis />
        <ThemeToggle />
        <main class="w-full max-w-3xl mx-auto flex flex-col gap-6 text-left">
            <header class="space-y-2">
                <h1 class="text-4xl font-semibold">
                    Ideas, notas y aprendizajes
                </h1>
                <a
                    class="inline-flex items-center gap-4 mt-4 text-base font-semibold hover:text-black/40 dark:hover:text-white/40"
                    href="/"
                >
                    ← Volver al inicio
                </a>
            </header>

            <section class="space-y-4">
                {
                    articles.length === 0 ? (
                        <p class="text-black/60 dark:text-white/60">
                            Todavía no hay artículos. Sube un archivo{" "}
                            <code class="font-mono">.md</code> a la carpeta
                            <code class="font-mono">articles/</code>.
                        </p>
                    ) : (
                        <ul class="space-y-4">
                            {articles.map((article) => (
                                <li class="border-2 border-black/10 p-4 hover:border-black/30 transition-colors dark:border-white/10 dark:hover:border-white/30">
                                    <article class="space-y-2">
                                        <p class="text-sm text-black/40 dark:text-white/40">
                                            {article.publishedAt
                                                ? new Date(
                                                      article.publishedAt,
                                                  ).toLocaleDateString(
                                                      "es-CL",
                                                      {
                                                          year: "numeric",
                                                          month: "long",
                                                          day: "numeric",
                                                      },
                                                  )
                                                : "Sin fecha"}
                                        </p>
                                        <h2 class="text-2xl font-semibold">
                                            {article.title}
                                        </h2>
                                        <p class="text-black/70 dark:text-white/70">
                                            {article.excerpt ||
                                                "Sin descripción"}
                                        </p>
                                        <a
                                            class="font-semibold hover:text-black/40 dark:hover:text-white/40"
                                            href={`/articles/${article.slug}`}
                                        >
                                            leer artículo completo →
                                        </a>
                                    </article>
                                </li>
                            ))}
                        </ul>
                    )
                }
            </section>
        </main>
    </body>
</html>
