---
import { listLegacyArticleSlugRoutes } from "../../services/articles";
import { getLegacyBlogSlugRedirect } from "../../services/blogRedirects";

export async function getStaticPaths() {
    const routes = await listLegacyArticleSlugRoutes();

    return routes.map((route) => ({
        params: { slug: route.slug },
    }));
}

const { slug } = Astro.params;

return Astro.redirect(getLegacyBlogSlugRedirect(slug), 301);
---
