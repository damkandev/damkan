---
import "../styles/global.css";
import Lenis from "../components/Lenis.astro";
import ThemeToggle from "../components/ThemeToggle.astro";
import { listArticles } from "../services/articles";

const articles = await listArticles();
const latestArticles = articles.slice(0, 3);
---

<html lang="en">
    <head>
        <meta charset="utf-8" />
        <link
            rel="preload"
            href="/fonts/lora-latin.woff2"
            as="font"
            type="font/woff2"
            crossorigin="anonymous"
        />
        <meta name="viewport" content="width=device-width" />
        <meta name="generator" content={Astro.generator} />
        <title>Damián Panes</title>
        <script is:inline>
            (function () {
                var s = localStorage.getItem("theme");
                var p = window.matchMedia(
                    "(prefers-color-scheme: dark)",
                ).matches;
                if (s === "dark" || (!s && p)) {
                    document.documentElement.classList.add("dark");
                }
            })();
        </script>
    </head>
    <body
        class="min-h-screen flex items-center justify-center bg-[#FFFCFC] text-[#24221D] p-8 transition-colors dark:bg-[#1c1a16] dark:text-[#f0ede6]"
    >
        <Lenis />
        <ThemeToggle />
        <main class="w-full max-w-3xl mx-auto flex flex-col gap-4 text-left">
            <h1 class="text-4xl font-semibold">Damián Panes</h1>
            <p class="text-lg leading-relaxed">
                Me gusta el helado de pasas al ron, tengo 5 veces repetidas el
                mismo par de zapatillas pero aparte de eso me gusta mucho
                programar y crear empresas, principalmente solucionar problemas.
            </p>

            <section class="space-y-4">
                <h2 class="text-2xl font-semibold">Artículos</h2>
                {
                    latestArticles.length === 0 ? (
                        <p class="text-sm text-black/40 dark:text-white/40">
                            Aún no hay artículos cargados.
                        </p>
                    ) : (
                        <ul class="grid gap-3">
                            {latestArticles.map((article) => (
                                <li>
                                    <a
                                        class="block border-2 border-black/10 p-4 transition hover:border-black/30 dark:border-white/10 dark:hover:border-white/30"
                                        href={`/articles/${article.slug}`}
                                    >
                                        <p class="text-xl font-medium">
                                            {article.title}
                                        </p>
                                        <p class="text-slate-600 dark:text-slate-400">
                                            {article.excerpt ||
                                                "Sin descripción breve."}
                                        </p>
                                    </a>
                                </li>
                            ))}
                        </ul>
                    )
                }
                <a
                    class="font-semibold hover:text-black/30 dark:hover:text-white/30"
                    href="/articles">ver más</a
                >
            </section>

            <section class="space-y-4">
                <h3 class="text-xl font-semibold">Redes Sociales</h3>
                <ul
                    class="list-disc list-inside text-base text-current space-y-2"
                >
                    <li>
                        <a
                            class="hover:underline"
                            href="https://www.linkedin.com/in/damianpanes/"
                            rel="noopener noreferrer"
                            target="_blank">LinkedIn</a
                        >
                    </li>
                    <li>
                        <a
                            class="hover:underline"
                            href="https://github.com/damkandev"
                            rel="noopener noreferrer"
                            target="_blank">GitHub</a
                        >
                    </li>
                    <li>
                        <a
                            class="hover:underline"
                            href="https://www.instagram.com/damian.panes/"
                            rel="noopener noreferrer"
                            target="_blank">Instagram</a
                        >
                    </li>
                    <li>
                        <a
                            class="hover:underline"
                            href="https://www.goodreads.com/user/show/196006762-dami-n-panes"
                            rel="noopener noreferrer"
                            target="_blank">GoodReads</a
                        >
                    </li>
                    <li>
                        <a
                            class="hover:underline"
                            href="https://www.youtube.com/@damianpanes"
                            rel="noopener noreferrer"
                            target="_blank">Youtube</a
                        >
                    </li>
                </ul>
            </section>
        </main>
    </body>
</html>
