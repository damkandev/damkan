---
import PreferredLocaleRedirect from "../components/PreferredLocaleRedirect.astro";
import { getLocalizedHomePath } from "../i18n/routes";

const routesByLocale = {
  es: getLocalizedHomePath("es"),
  en: getLocalizedHomePath("en"),
};
---

<PreferredLocaleRedirect fallbackPath={routesByLocale.es} routesByLocale={routesByLocale} />
